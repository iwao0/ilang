{
  "name": "ilang",
  "displayName": "ilang",
  "description": "Syntax highlighting and language server for the ilang language (.il)",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": ["Programming Languages"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:ilang"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ilang",
        "aliases": ["ilang", "il"],
        "extensions": [".il"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/ilang-light.svg",
          "dark": "./icons/ilang-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "ilang",
        "scopeName": "source.ilang",
        "path": "./syntaxes/ilang.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "ilang",
      "properties": {
        "ilang.serverPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the ilang-lsp binary (ilang-lsp.exe on Windows). If empty, falls back to the ILANG_LSP_PATH env var, then to `<workspace>/target/release/ilang-lsp[.exe]`, then `target/debug/ilang-lsp[.exe]`."
        }
      }
    },
    "configurationDefaults": {
      "[ilang]": {
        "editor.wordBasedSuggestions": "off"
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p ."
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.70.0",
    "typescript": "^5.4.0"
  }
}
