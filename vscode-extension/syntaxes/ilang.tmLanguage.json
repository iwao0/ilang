{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ilang",
  "scopeName": "source.ilang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#attributes" },
    { "include": "#enum-variant-keyword" },
    { "include": "#fn-decl" },
    { "include": "#class-decl" },
    { "include": "#interface-decl" },
    { "include": "#enum-decl" },
    { "include": "#struct-decl" },
    { "include": "#union-decl" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#fn-call" },
    { "include": "#type-name" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ilang",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ilang",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.ilang",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.ilang",
          "match": "\\\\."
        }
      ]
    },
    "attributes": {
      "name": "meta.attribute.ilang",
      "match": "@[A-Za-z_][A-Za-z0-9_]*",
      "captures": {
        "0": { "name": "entity.name.function.decorator.ilang" }
      }
    },
    "enum-variant-keyword": {
      "comment": "Reserved words used as enum variant names — both in declarations (`return = 40`, `static = 0`, `u8 = 0`) and at use sites via dotted access (`Scancode.return`, `TextureAccess.static`). Match before #keywords / #types so those scopes don't fire; no `name` is assigned so the token renders with the editor's default identifier colour. The variant-declaration arm uses a negative lookbehind for `:` so type annotations like `const m: string = \"...\"` are NOT swallowed.",
      "patterns": [
        {
          "comment": "Variant declaration: `name = value` form. Negative lookbehind for `:` + whitespace keeps type annotations like `const m: string = ...` routing to #types instead of being swallowed as a discriminant name.",
          "match": "(?<!:\\s*)\\b(as|bool|break|class|const|continue|deinit|elif|else|enum|f32|f64|false|fn|for|get|i16|i32|i64|i8|if|in|init|interface|let|loop|match|new|none|override|pub|return|set|some|static|string|struct|super|this|true|u16|u32|u64|u8|union|use|void|while)(?=\\s*=)"
        },
        {
          "comment": "Dotted access: `Enum.variant`. The reserved word follows a `.`.",
          "match": "(?<=\\.)(as|bool|break|class|const|continue|deinit|elif|else|enum|f32|f64|false|fn|for|get|i16|i32|i64|i8|if|in|init|interface|let|loop|match|new|none|override|pub|return|set|some|static|string|struct|super|this|true|u16|u32|u64|u8|union|use|void|while)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ilang",
          "match": "\\b(if|elif|else|while|loop|for|in|break|continue|return|match)\\b"
        },
        {
          "name": "keyword.declaration.ilang",
          "match": "\\b(let|const|fn|class|interface|enum|struct|union|use|pub|override|init|deinit|static|get|set)\\b"
        },
        {
          "name": "keyword.other.ilang",
          "match": "\\b(new|this|super|as)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "comment": "SIMD vector types — `simd.f32x4`, `simd.i32x4`, etc. Matched before the scalar list so the dotted form colours as one unit.",
          "name": "support.type.simd.ilang",
          "match": "\\bsimd\\.(?:f32|f64|i8|i16|i32|i64)x[0-9]+\\b"
        },
        {
          "name": "support.type.ilang",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|string|void|char|size_t|ssize_t)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.ilang",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.ilang",
          "match": "\\b(none|some)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.ilang",
          "match": "\\b0[xX][0-9a-fA-F_]+(?:[iuf](?:8|16|32|64))?\\b"
        },
        {
          "name": "constant.numeric.float.ilang",
          "match": "\\b[0-9][0-9_]*\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?(?:f(?:32|64))?\\b"
        },
        {
          "name": "constant.numeric.integer.ilang",
          "match": "\\b[0-9][0-9_]*(?:[iuf](?:8|16|32|64))?\\b"
        }
      ]
    },
    "fn-decl": {
      "comment": "Function / property-accessor declaration: `fn name`, `get name`, `set name`. Captures the name explicitly so it renders as an identifier even when it shadows a type keyword (`pub get string(): NSString` etc.).",
      "match": "\\b(fn|get|set)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.ilang" },
        "2": { "name": "entity.name.function.ilang" }
      }
    },
    "class-decl": {
      "match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.ilang" },
        "2": { "name": "entity.name.type.class.ilang" }
      }
    },
    "interface-decl": {
      "match": "\\b(interface)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.ilang" },
        "2": { "name": "entity.name.type.interface.ilang" }
      }
    },
    "enum-decl": {
      "match": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.ilang" },
        "2": { "name": "entity.name.type.enum.ilang" }
      }
    },
    "struct-decl": {
      "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.ilang" },
        "2": { "name": "entity.name.type.struct.ilang" }
      }
    },
    "union-decl": {
      "match": "\\b(union)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.ilang" },
        "2": { "name": "entity.name.type.union.ilang" }
      }
    },
    "fn-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "entity.name.function.call.ilang" }
      }
    },
    "type-name": {
      "name": "entity.name.type.ilang",
      "comment": "Capitalised identifier in type position. Negative lookahead for `\\s*:` keeps struct-literal field names like `BlendEnable: 0` and `RenderTargetWriteMask: 0` from being painted as types — those start with a capital because they mirror Win32 / D3D12 SDK field names, but they're plain property assignments, not type references.",
      "match": "\\b[A-Z][A-Za-z0-9_]+\\b(?!\\s*:)"
    },
    "operators": {
      "name": "keyword.operator.ilang",
      "match": "(\\+|-|\\*|/|%|==|!=|<=|>=|<<|>>|&&|\\|\\||!|=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|<|>|&|\\||\\^|~|\\?|\\.\\.|\\.\\.=)"
    }
  }
}
